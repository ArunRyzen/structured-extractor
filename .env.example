# Copy to `.env` and fill in. The real `.env` is gitignored — never commit it.

# Which backend to use: gemini | anthropic | openai
PROVIDER=gemini

# Credentials (set the one matching PROVIDER)
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Models (override as needed)
GEMINI_MODEL=gemini-2.5-flash
ANTHROPIC_MODEL=claude-opus-4-8
OPENAI_MODEL=gpt-4o

# Generation / reliability
MAX_TOKENS=4096
MAX_RETRIES=2

# Set to 1 to print every AI request/response to stderr — great for learning
LLM_DEBUG=
